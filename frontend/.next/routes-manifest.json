{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [
      {
        "source": "/api/:path*",
        "destination": "http://localhost:3101/api/:path*",
        "regex": "^/api(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      },
      {
        "source": "/line/:path*",
        "destination": "http://localhost:3101/line/:path*",
        "regex": "^/line(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))?(?:/)?$"
      }
    ],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/admin/customers/[id]",
      "regex": "^/admin/customers/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/customers/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/admin/orders/[id]",
      "regex": "^/admin/orders/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/admin/orders/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/admin",
      "regex": "^/admin(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin(?:/)?$"
    },
    {
      "page": "/admin/customers",
      "regex": "^/admin/customers(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/customers(?:/)?$"
    },
    {
      "page": "/admin/dev",
      "regex": "^/admin/dev(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/dev(?:/)?$"
    },
    {
      "page": "/admin/landing",
      "regex": "^/admin/landing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/landing(?:/)?$"
    },
    {
      "page": "/admin/messages/account-types",
      "regex": "^/admin/messages/account\\-types(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/messages/account\\-types(?:/)?$"
    },
    {
      "page": "/admin/messages/history",
      "regex": "^/admin/messages/history(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/messages/history(?:/)?$"
    },
    {
      "page": "/admin/messages/send",
      "regex": "^/admin/messages/send(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/messages/send(?:/)?$"
    },
    {
      "page": "/admin/messages/templates",
      "regex": "^/admin/messages/templates(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/messages/templates(?:/)?$"
    },
    {
      "page": "/admin/orders",
      "regex": "^/admin/orders(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/orders(?:/)?$"
    },
    {
      "page": "/admin/site",
      "regex": "^/admin/site(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/admin/site(?:/)?$"
    },
    {
      "page": "/liff",
      "regex": "^/liff(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/liff(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}